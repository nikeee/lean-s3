{
  "name": "lean-s3",
  "version": "0.9.24",
  "description": "A server-side S3 API for the regular user.",
  "keywords": [
    "AWS S3",
    "Azure Blob Storage",
    "Ceph",
    "Google Cloud Storage",
    "b2",
    "b2 client",
    "backblaze",
    "client",
    "cloudflare",
    "cloudflare r2",
    "mibion",
    "r2",
    "r2 client",
    "s3",
    "s3 client",
    "s3 sdk"
  ],
  "license": "MIT",
  "author": "Niklas Mollenhauer",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikeee/lean-s3"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "test": "tsgo && node --test src/*.test.ts src/test/*.test.ts",
    "test:bun": "tsgo && bun test src/*.test.ts src/test/*.test.ts",
    "test:integration": "tsgo && node --test src/test/test.integration.ts",
    "ci": "oxlint --type-aware --deny-warnings -f github",
    "docs": "typedoc",
    "format": "oxfmt",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@testcontainers/localstack": "^12.0.0",
    "@testcontainers/minio": "^12.0.0",
    "@testcontainers/s3mock": "^12.0.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260521.1",
    "expect": "^30.4.1",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "testcontainers": "^12.0.0",
    "tsdown": "^0.22.0",
    "typedoc": "^0.28.19"
  },
  "optionalDependencies": {
    "undici": "^8.3.0"
  },
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || ^26.1.0"
  }
}
